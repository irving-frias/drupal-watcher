{
  "name": "irving-frias/drupal-watcher",
  "description": "Watcher para Drupal que vigila módulos y temas custom y ejecuta drush cr. Soporta DDEV/Lando, con gestión de rutas.",
  "type": "library",
  "license": "MIT",
  "bin": [
    "bin/drupal-watcher"
  ],
  "require": {
    "php": ">=8.1"
  },
  "scripts": {
    "watcher:start": [
      "bun run bin/drupal-watcher start"
    ],
    "watcher:list": [
      "bun run bin/drupal-watcher list"
    ],
    "watcher:add": [
      "bun run bin/drupal-watcher add"
    ],
    "watcher:remove": [
      "bun run bin/drupal-watcher remove"
    ],
    "watcher:reset": [
      "bun run bin/drupal-watcher reset"
    ]
  }
}
