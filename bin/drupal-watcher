#!/bin/bash
# Drupal Watcher — binary launcher
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
BINARY="$DIR/drupal-watcher-go"

# Run setup: download binary if missing, ensure vendor/bin symlink
php "$DIR/install.php"

if [ ! -x "$BINARY" ]; then
  echo "Error: Drupal Watcher binary not found at $BINARY" >&2
  echo "Download manually from: https://github.com/irving-frias/drupal-watcher/releases" >&2
  exit 1
fi

exec "$BINARY" "$@"
