#!/usr/bin/env php
<?php
$binDir = __DIR__;
$binaryPath = $binDir . '/drupal-watcher-go';

if (!file_exists($binaryPath) || !is_executable($binaryPath)) {
    require $binDir . '/install.php';
}

if (!file_exists($binaryPath) || !is_executable($binaryPath)) {
    fwrite(STDERR, "Error: Drupal Watcher binary not found at {$binaryPath}\n");
    fwrite(STDERR, "Download manually from: https://github.com/irving-frias/drupal-watcher/releases\n");
    exit(1);
}

$args = array_slice($argv, 1);

if (function_exists('pcntl_exec')) {
    pcntl_exec($binaryPath, $args);
}

$cmd = $binaryPath;
foreach ($args as $arg) {
    $cmd .= ' ' . escapeshellarg($arg);
}
passthru($cmd, $exitCode);
exit($exitCode);
