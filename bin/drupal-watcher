#!/bin/bash
# Drupal Watcher — Go binary launcher
DIR="$(cd "$(dirname "$0")" && pwd)"
BINARY="$DIR/drupal-watcher-go"

if [ ! -x "$BINARY" ]; then
  # Try building from source
  if command -v go &>/dev/null; then
    echo "Building Drupal Watcher binary (one-time compile)..." >&2
    cd "$DIR/.."
    go build -o "$BINARY" ./cmd/drupal-watcher
    if [ $? -eq 0 ]; then
      exec "$BINARY" "$@"
    fi
    echo "Error: build failed." >&2
  fi
  echo "Download a pre-built binary from: https://github.com/irving-frias/drupal-watcher/releases" >&2
  echo "Place it at: $BINARY" >&2
  exit 1
fi

exec "$BINARY" "$@"
