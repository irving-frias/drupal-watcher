#!/usr/bin/env bun

import { existsSync, accessSync, constants } from "fs";
import { $ } from "bun";
import path from "path";

const RED = "\x1b[31m";
const GREEN = "\x1b[32m";
const YELLOW = "\x1b[33m";
const BLUE = "\x1b[34m";
const NC = "\x1b[0m";

const CONFIG_FILE = path.join(process.cwd(), "watcher.config.json");
const POSSIBLE_DOCROOTS = ["docroot", "web", "html", "public", "drupal"];

// --- Memoized caches ---
let _cachedRoot = null;
let _cachedEnv = null;
let _configCache = null;

function detectDrupalRoot() {
  if (_cachedRoot !== null) return _cachedRoot;
  const root = process.cwd();
  for (const dir of POSSIBLE_DOCROOTS) {
    const fullPath = path.join(root, dir);
    if (!existsSync(fullPath)) continue;
    if (existsSync(path.join(fullPath, "core")) ||
        existsSync(path.join(fullPath, "modules")) ||
        existsSync(path.join(fullPath, "themes"))) {
      _cachedRoot = dir;
      return dir;
    }
  }
  _cachedRoot = null;
  return null;
}

function detectEnvironment() {
  if (_cachedEnv !== null) return _cachedEnv;
  const root = process.cwd();
  if (existsSync(path.join(root, ".ddev"))) _cachedEnv = "ddev";
  else if (existsSync(path.join(root, ".lando.yml")) || existsSync(path.join(root, ".lando"))) _cachedEnv = "lando";
  else _cachedEnv = "local";
  return _cachedEnv;
}

// --- Config ---
function getDefaultConfig() {
  const drupalRoot = detectDrupalRoot() || "docroot";
  return {
    routes: [`${drupalRoot}/modules/custom`, `${drupalRoot}/themes/custom`],
    patterns: [".html.twig", ".inc", ".yml", ".module", ".theme"],
    excludePatterns: [],
    debounce: 800,
    drushCmd: null,
    drushCommand: "cr",
    drushArgs: [],
    postClearCommands: [],
    drupalRoot,
  };
}

async function loadConfig() {
  if (_configCache) return _configCache;

  const configFile = Bun.file(CONFIG_FILE);
  if (!(await configFile.exists())) {
    const def = getDefaultConfig();
    await Bun.write(CONFIG_FILE, JSON.stringify(def, null, 2));
    _configCache = { ...def };
    return _configCache;
  }

  try {
    const raw = await configFile.text();
    const config = JSON.parse(raw);

    if (!config.drupalRoot) {
      const detected = detectDrupalRoot();
      if (detected) {
        config.drupalRoot = detected;
        config.routes = config.routes.map(r => {
          const p = r.split("/");
          if (p.length > 0 && POSSIBLE_DOCROOTS.includes(p[0]) && p[0] !== detected) {
            return r.replace(p[0], detected);
          }
          return r;
        });
        await saveConfig(config);
      }
    }

    _configCache = { ...getDefaultConfig(), ...config };
    return _configCache;
  } catch {
    console.error(`${RED}Error al leer configuración. Usando defaults.${NC}`);
    const def = getDefaultConfig();
    _configCache = { ...def };
    return _configCache;
  }
}

async function saveConfig(config) {
  await Bun.write(CONFIG_FILE, JSON.stringify(config, null, 2));
  _configCache = null;
}

// --- Drush resolution ---
function getDrushCommand(config) {
  if (config.drushCmd) return config.drushCmd;
  const env = detectEnvironment();
  if (env === "ddev") return "ddev drush";
  if (env === "lando") return "lando drush";
  const vendorDrush = path.join(process.cwd(), "vendor/bin/drush");
  const binDrush = path.join(process.cwd(), "bin/drush");
  if (existsSync(vendorDrush)) {
    try { accessSync(vendorDrush, constants.X_OK); return vendorDrush; } catch {}
  }
  if (existsSync(binDrush)) {
    try { accessSync(binDrush, constants.X_OK); return binDrush; } catch {}
  }
  return "drush";
}

function getDrushSpawnArgs(config) {
  const cmdStr = getDrushCommand(config);
  const parts = cmdStr.split(/\s+/);
  const args = [...parts.slice(1)];
  if (config.drushCommand) args.push(config.drushCommand);
  if (config.drushArgs?.length > 0) args.push(...config.drushArgs);
  return { cmd: parts[0], args };
}

// --- Adaptive debounce with change accumulation ---
let debounceTimer = null;
let changeAccumulator = new Map();

function resetDebounce() {
  if (debounceTimer) {
    clearTimeout(debounceTimer);
    debounceTimer = null;
  }
  changeAccumulator.clear();
}

async function runCacheClear(drushBase, drushArgsArray, postClearCommands) {
  const files = Array.from(changeAccumulator.keys());
  changeAccumulator.clear();
  if (files.length === 0) return;

  const suffix = files.length > 1 ? ` (${files.length} archivos)` : "";
  console.log(`${YELLOW}🔄 Limpiando caché...${suffix}${NC}`);

  try {
    const { exitCode, stderr } = await $`${drushBase} ${drushArgsArray}`.quiet().nothrow();

    if (exitCode === 0) {
      console.log(`${GREEN}✅ Caché limpiada correctamente.${NC}`);
    } else {
      const errText = await new Response(stderr).text();
      console.error(`${RED}❌ Error drush (exit ${exitCode}):${NC} ${errText || "drush no disponible"}`);
    }

    for (const cmd of postClearCommands) {
      console.log(`${YELLOW}⚡ ${cmd}${NC}`);
      await $`${cmd}`.nothrow();
    }
  } catch (error) {
    console.error(`${RED}❌ Error:${NC} ${error.message}`);
  }
}

function scheduleCacheClear(config) {
  if (debounceTimer) clearTimeout(debounceTimer);
  const { cmd, args } = getDrushSpawnArgs(config);
  debounceTimer = setTimeout(() => {
    debounceTimer = null;
    runCacheClear(cmd, args, config.postClearCommands || []);
  }, config.debounce || 800);
}

// --- Commands ---
async function cmdList() {
  const config = await loadConfig();
  const drushSpawn = getDrushSpawnArgs(config);
  const drupalRoot = config.drupalRoot || detectDrupalRoot() || "no detectado";

  console.log(`${BLUE}📋 Configuración del watcher:${NC}`);
  console.log(`  ${YELLOW}Directorio raíz:${NC} ${drupalRoot}`);
  console.log(`  ${YELLOW}Entorno:${NC} ${detectEnvironment()}`);
  console.log(`  ${YELLOW}Rutas vigiladas:${NC}`);
  config.routes.forEach(r => console.log(`    - ${r}`));
  console.log(`  ${YELLOW}Patrones:${NC} ${config.patterns.join(", ")}`);
  if (config.excludePatterns?.length > 0) {
    console.log(`  ${YELLOW}Excluidos:${NC} ${config.excludePatterns.join(", ")}`);
  }
  console.log(`  ${YELLOW}Debounce:${NC} ${config.debounce}ms`);
  console.log(`  ${YELLOW}Drush:${NC} ${drushSpawn.cmd} ${drushSpawn.args.join(" ")}`);
  if (config.postClearCommands?.length > 0) {
    console.log(`  ${YELLOW}Post-clear:${NC} ${config.postClearCommands.join("; ")}`);
  }
}

async function cmdAdd(newRoute) {
  if (!newRoute) {
    console.error(`${RED}❌ Especifica una ruta. Ej: vendor/bin/drupal-watcher add modules/contrib${NC}`);
    process.exit(1);
  }
  const config = await loadConfig();
  const drupalRoot = config.drupalRoot || detectDrupalRoot();
  if (!drupalRoot) {
    console.error(`${RED}❌ No se pudo detectar el directorio raíz de Drupal.${NC}`);
    process.exit(1);
  }

  let normalized = path.normalize(newRoute).replace(/^\.\//, "");
  if (!normalized.startsWith(drupalRoot) && !POSSIBLE_DOCROOTS.some(r => normalized.startsWith(r))) {
    normalized = path.join(drupalRoot, normalized);
  }

  if (config.routes.includes(normalized)) {
    console.log(`${YELLOW}⚠️ La ruta ya está en la lista.${NC}`);
    return;
  }

  if (!existsSync(path.join(process.cwd(), normalized))) {
    console.error(`${RED}❌ La ruta no existe: ${normalized}${NC}`);
    process.exit(1);
  }

  config.routes.push(normalized);
  await saveConfig(config);
  console.log(`${GREEN}✅ Ruta añadida: ${normalized}${NC}`);
  await cmdList();
}

async function cmdRemove(routeToRemove) {
  if (!routeToRemove) {
    console.error(`${RED}❌ Especifica una ruta. Ej: vendor/bin/drupal-watcher remove modules/contrib${NC}`);
    process.exit(1);
  }
  const config = await loadConfig();
  const normalized = path.normalize(routeToRemove).replace(/^\.\//, "");
  const index = config.routes.indexOf(normalized);
  if (index === -1) {
    console.error(`${RED}❌ La ruta no está en la lista.${NC}`);
    await cmdList();
    process.exit(1);
  }
  config.routes.splice(index, 1);
  await saveConfig(config);
  console.log(`${GREEN}✅ Ruta eliminada: ${normalized}${NC}`);
  await cmdList();
}

async function cmdReset() {
  const config = await loadConfig();
  const def = getDefaultConfig();
  config.routes = [...def.routes];
  config.drupalRoot = def.drupalRoot;
  await saveConfig(config);
  console.log(`${GREEN}✅ Rutas restablecidas a valores por defecto.${NC}`);
  await cmdList();
}

// --- Start ---
let watcherHandle = null;

async function cmdStart() {
  console.log(`${YELLOW}🚀 Iniciando Drupal Watcher${NC}`);
  const config = await loadConfig();
  const drupalRoot = config.drupalRoot || detectDrupalRoot();

  if (!drupalRoot) {
    console.error(`${RED}❌ No se pudo detectar el directorio raíz de Drupal.${NC}`);
    console.error(`${YELLOW}   Estructuras soportadas: ${POSSIBLE_DOCROOTS.join(", ")}${NC}`);
    process.exit(1);
  }

  const { cmd: drushBase, args: drushArgs } = getDrushSpawnArgs(config);
  const drushCmdStr = getDrushCommand(config);

  console.log(`${GREEN}📁 Directorio raíz:${NC} ${drupalRoot}`);
  console.log(`${GREEN}🌐 Entorno:${NC} ${detectEnvironment()}`);
  console.log(`${GREEN}🔧 Drush:${NC} ${drushCmdStr} ${config.drushCommand}`);

  // Health check via Bun shell
  const healthCmd = [...drushCmdStr.split(/\s+/), "status", "--format=json"].join(" ");
  const healthResult = await $`${healthCmd}`.quiet().nothrow();
  if (healthResult.exitCode !== 0) {
    console.log(`${YELLOW}⚠️ Drush no responde. El watcher iniciará igualmente.${NC}`);
  }

  // Show routes
  console.log(`${GREEN}👀 Vigilando rutas:${NC}`);
  let hasValidRoute = false;
  const rootPath = path.join(process.cwd(), drupalRoot);

  config.routes.forEach(route => {
    if (!existsSync(path.join(process.cwd(), route))) {
      console.log(`${YELLOW}⚠️ Ruta no existe (se omite):${NC} ${route}`);
      return;
    }
    hasValidRoute = true;
    console.log(`  - ${route}`);
  });

  if (!hasValidRoute) {
    console.error(`${RED}❌ Ninguna de las rutas configuradas existe.${NC}`);
    console.error(`${YELLOW}   Añade rutas con 'vendor/bin/drupal-watcher add'${NC}`);
    process.exit(1);
  }

  // Single recursive Bun.watch on drupal root
  const routeSuffixes = config.routes.map(r => r.replace(`${drupalRoot}/`, "").replace(drupalRoot, ""));

  const onChange = (info) => {
    if (!info?.path) return;
    const normalized = path.normalize(info.path);

    if (!routeSuffixes.some(suffix => normalized.startsWith(suffix))) return;
    if (!config.patterns.some(p => info.path.endsWith(p))) return;
    if (config.excludePatterns?.some(p => info.path.endsWith(p))) return;

    if (!changeAccumulator.has(info.path)) {
      const displayName = path.basename(info.path);
      const total = changeAccumulator.size + 1;
      console.log(`${GREEN}📝 ${displayName}${total > 1 ? ` (${total})` : ""}${NC}`);
    }
    changeAccumulator.set(info.path, Date.now());
    scheduleCacheClear(config);
  };

  const onError = (err) => {
    console.error(`${RED}❌ Error en watcher:${NC} ${err?.message || err}`);
  };

  // Use Bun.watch natively
  try {
    watcherHandle = Bun.watch({
      paths: [rootPath],
      recursive: true,
      onChange,
      onError,
    });
  } catch {
    // Fallback to fs.watch if Bun.watch is not available
    const { watch: fsWatch } = await import("fs");
    watcherHandle = fsWatch(rootPath, { recursive: true }, (eventType, filename) => {
      if (!filename) return;
      onChange({ path: filename, type: eventType });
    });
    watcherHandle.on("error", onError);
  }

  console.log(`${GREEN}✅ Watcher activo. Esperando cambios... (Ctrl+C para salir)${NC}`);

  process.on("SIGINT", () => {
    console.log(`\n${YELLOW}🛑 Deteniendo watcher...${NC}`);
    resetDebounce();
    if (watcherHandle) {
      try {
        if (typeof watcherHandle.stop === "function") watcherHandle.stop();
        else if (typeof watcherHandle.close === "function") watcherHandle.close();
      } catch {}
    }
    process.exit(0);
  });
}

// --- Help ---
function cmdHelp() {
  const bold = (s) => `${GREEN}${s}${NC}`;
  const dim = (s) => `${YELLOW}${s}${NC}`;

  console.log(`${YELLOW}🚀 Drupal Watcher${NC} — Vigila archivos de Drupal y ejecuta drush cr automáticamente`);
  console.log();
  console.log(`${BLUE}Uso:${NC}`);
  console.log(`  vendor/bin/drupal-watcher ${bold("<comando>")} ${dim("[argumentos]")}`);
  console.log();
  console.log(`${BLUE}Comandos:${NC}`);
  console.log(`  ${bold("start")}                   Inicia el watcher (predeterminado)`);
  console.log(`  ${bold("list")}                    Muestra la configuración actual`);
  console.log(`  ${bold("add")}    ${dim("<ruta>")}          Añade una ruta a vigilar`);
  console.log(`  ${bold("remove")} ${dim("<ruta>")}          Elimina una ruta`);
  console.log(`  ${bold("reset")}                   Restablece las rutas por defecto`);
  console.log(`  ${bold("help, -h, --help")}        Muestra esta ayuda`);
  console.log();
  console.log(`${BLUE}Ejemplos:${NC}`);
  console.log(`  vendor/bin/drupal-watcher start`);
  console.log(`  vendor/bin/drupal-watcher add docroot/modules/contrib`);
  console.log(`  vendor/bin/drupal-watcher remove docroot/modules/contrib`);
  console.log(`  vendor/bin/drupal-watcher list`);
  console.log();
  console.log(`${BLUE}Configuración:${NC} watcher.config.json`);
  console.log(`${BLUE}Documentación:${NC} README.md`);
}

// --- Main ---
async function main() {
  const args = process.argv.slice(2);
  const command = args[0] || "help";
  const isHelp = !command || command === "help" || command === "--help" || command === "-h";

  if (isHelp) {
    cmdHelp();
    return;
  }

  switch (command) {
    case "list":   await cmdList(); break;
    case "add":    await cmdAdd(args[1]); break;
    case "remove": await cmdRemove(args[1]); break;
    case "reset":  await cmdReset(); break;
    case "start":  await cmdStart(); break;
    default:
      console.error(`${RED}❌ Comando desconocido: ${command}${NC}`);
      console.log(`   Ejecuta ${GREEN}vendor/bin/drupal-watcher help${NC} para ver los comandos disponibles.`);
      process.exit(1);
  }
}

await main();
