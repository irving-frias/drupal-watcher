{
  "name": "drupal-watcher",
  "version": "0.3.0",
  "description": "Drupal file watcher — monitors custom modules/themes and auto-runs drush cr",
  "type": "module",
  "bin": {
    "drupal-watcher": "bin/drupal-watcher"
  },
  "scripts": {
    "start": "bun run bin/drupal-watcher start",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "build": "bun build --compile ./bin/drupal-watcher --outfile ./dist/drupal-watcher",
    "build:linux": "bun build --compile --target=bun-linux-x64 ./bin/drupal-watcher --outfile ./dist/drupal-watcher-linux",
    "build:mac": "bun build --compile --target=bun-darwin-arm64 ./bin/drupal-watcher --outfile ./dist/drupal-watcher-macos",
    "build:win": "bun build --compile --target=bun-windows-x64 ./bin/drupal-watcher --outfile ./dist/drupal-watcher.exe"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
